@model Escale.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var startDate = (DateTime)ViewBag.StartDate;
    var endDate = (DateTime)ViewBag.EndDate;
    var isToday = startDate == DateTime.Today && endDate == DateTime.Today;
}

@await Html.PartialAsync("_ApiError")

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 page-header">
    <div>
        <h1 class="h2"><i class="fas fa-chart-line me-2"></i>Dashboard</h1>
        <p class="text-muted mb-0">
            @if (isToday)
            {
                <span>Welcome back! Here's what's happening today.</span>
            }
            else
            {
                <span>Showing data from @startDate.ToString("dd MMM yyyy") to @endDate.ToString("dd MMM yyyy")</span>
            }
        </p>
    </div>
    <div class="btn-toolbar mb-2 mb-md-0">
        <form asp-action="Index" method="get" class="d-flex align-items-center gap-2">
            <div class="btn-group me-2">
                <a asp-action="Index" class="btn btn-sm @(isToday ? "btn-primary" : "btn-outline-secondary")">
                    <i class="fas fa-calendar-day me-1"></i>Today
                </a>
                <a asp-action="Index" asp-route-startDate="@DateTime.Today.AddDays(-6).ToString("yyyy-MM-dd")" asp-route-endDate="@DateTime.Today.ToString("yyyy-MM-dd")" class="btn btn-sm @(!isToday && (endDate - startDate).Days == 6 ? "btn-primary" : "btn-outline-secondary")">
                    <i class="fas fa-calendar-week me-1"></i>Week
                </a>
                <a asp-action="Index" asp-route-startDate="@DateTime.Today.AddDays(-29).ToString("yyyy-MM-dd")" asp-route-endDate="@DateTime.Today.ToString("yyyy-MM-dd")" class="btn btn-sm @(!isToday && (endDate - startDate).Days == 29 ? "btn-primary" : "btn-outline-secondary")">
                    <i class="fas fa-calendar-alt me-1"></i>Month
                </a>
            </div>
            <input type="date" name="startDate" class="form-control form-control-sm" value="@startDate.ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")" style="width: 140px;" />
            <span class="text-muted">to</span>
            <input type="date" name="endDate" class="form-control form-control-sm" value="@endDate.ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")" style="width: 140px;" />
            <button type="submit" class="btn btn-sm btn-primary">
                <i class="fas fa-filter me-1"></i>Filter
            </button>
        </form>
    </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Stations</div>
                        <div id="stat-stations" class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalStations</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-gas-pump fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Revenue</div>
                        <div id="stat-sales" class="h5 mb-0 font-weight-bold text-gray-800">@((Model.TodaysSales - Model.CreditSales).ToString("N0")) RWF</div>
                        <div class="text-xs text-muted mt-1"><span id="stat-transactions">@(Model.TransactionCount - Model.CreditTransactionCount)</span> transactions</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-money-bill-wave fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-danger shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Credit Sales</div>
                        <div id="stat-credit" class="h5 mb-0 font-weight-bold text-gray-800">@Model.CreditSales.ToString("N0") RWF</div>
                        <div class="text-xs text-muted mt-1">@Model.CreditTransactionCount transactions</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-hand-holding-usd fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Low Stock Alerts</div>
                        <div id="stat-alerts" class="h5 mb-0 font-weight-bold @(Model.LowStockAlerts > 0 ? "text-danger" : "text-gray-800")">@Model.LowStockAlerts</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Top Station Performance -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card shadow">
            <div class="card-header py-3 d-flex justify-content-between align-items-center bg-dark">
                <h6 class="m-0 fw-bold text-white"><i class="fas fa-trophy me-2"></i>Top 5 Station Performance</h6>
                <a asp-controller="Stations" asp-action="Index" class="btn btn-sm btn-outline-light">View All Stations</a>
            </div>
            <div id="top-stations-container" class="card-body p-0">
                @if (Model.TopStations.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 60px;" class="text-center">Rank</th>
                                    <th>Station</th>
                                    <th class="text-end">Cash/MoMo/Card</th>
                                    <th class="text-end">Credit</th>
                                    <th class="text-end">Total Sales</th>
                                    <th class="text-center">Transactions</th>
                                    <th class="text-end">Volume (L)</th>
                                    <th style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var station in Model.TopStations)
                                {
                                    <tr>
                                        <td class="text-center">
                                            <span class="badge @(station.Rank == 1 ? "bg-warning text-dark" : station.Rank == 2 ? "bg-secondary" : station.Rank == 3 ? "bg-primary" : "bg-light text-dark") rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 30px; height: 30px; font-size: 0.8rem;">
                                                @station.Rank
                                            </span>
                                        </td>
                                        <td class="fw-semibold">@station.StationName</td>
                                        <td class="text-end text-success fw-bold">@station.CashSales.ToString("N0") RWF</td>
                                        <td class="text-end text-danger fw-bold">@station.CreditSales.ToString("N0") RWF</td>
                                        <td class="text-end fw-bold text-primary">@station.TotalSales.ToString("N0") RWF</td>
                                        <td class="text-center">@station.TransactionCount</td>
                                        <td class="text-end">@station.TotalLiters.ToString("N0")</td>
                                        <td class="text-center">
                                            <a asp-controller="Stations" asp-action="Details" asp-route-id="@station.StationId" class="text-muted"><i class="fas fa-chevron-right"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-chart-bar fa-2x mb-2 d-block"></i>
                        No station performance data available for this period.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row mb-4">
    <div class="col-lg-6 mb-3">
        <div class="card shadow">
            <div class="card-header py-3 bg-dark">
                <h6 class="m-0 fw-bold text-white">Sales Trend (Last 7 Days)</h6>
            </div>
            <div class="card-body">
                <canvas id="salesChart" height="100"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-3">
        <div class="card shadow">
            <div class="card-header py-3 bg-dark">
                <h6 class="m-0 fw-bold text-white">Sales by Fuel Type</h6>
            </div>
            <div class="card-body">
                <canvas id="fuelTypeChart" height="100"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-lg-12 mb-3">
        <div class="card shadow">
            <div class="card-header py-3 bg-dark">
                <h6 class="m-0 fw-bold text-white">Recent Transactions</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Station</th>
                                <th>Cashier</th>
                                <th>Customer</th>
                                <th>Fuel</th>
                                <th>Qty</th>
                                <th>Payment</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="recent-transactions-body">
                            @foreach (var txn in Model.RecentTransactions)
                            {
                                <tr>
                                    <td>@txn.Time.ToString("dd MMM HH:mm")</td>
                                    <td>@txn.StationName</td>
                                    <td>@txn.CashierName</td>
                                    <td>@(txn.CustomerName ?? "—")</td>
                                    <td>@txn.FuelType</td>
                                    <td>@txn.Quantity.ToString("N1")L</td>
                                    <td>
                                        @if (txn.PaymentMethod == "Credit")
                                        {
                                            <span class="badge bg-danger">Credit</span>
                                        }
                                        else if (txn.PaymentMethod == "MobileMoney")
                                        {
                                            <span class="badge bg-success">MoMo</span>
                                        }
                                        else if (txn.PaymentMethod == "Card")
                                        {
                                            <span class="badge bg-primary">Card</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Cash</span>
                                        }
                                    </td>
                                    <td class="text-end fw-bold">@txn.Total.ToString("N0") RWF</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Sales Trend Chart
    var salesCtx = document.getElementById('salesChart').getContext('2d');
    window.escaleSalesChart = new Chart(salesCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(Json.Serialize(Model.SalesChart.Select(s => s.Date))),
            datasets: [{
                label: 'Sales (RWF)',
                data: @Html.Raw(Json.Serialize(Model.SalesChart.Select(s => s.Sales))),
                borderColor: 'rgb(13, 110, 253)',
                backgroundColor: 'rgba(13, 110, 253, 0.1)',
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            }
        }
    });

    // Fuel Type Chart
    var fuelCtx = document.getElementById('fuelTypeChart').getContext('2d');
    window.escaleFuelChart = new Chart(fuelCtx, {
        type: 'pie',
        data: {
            labels: @Html.Raw(Json.Serialize(Model.FuelTypeChart.Select(f => f.FuelType))),
            datasets: [{
                data: @Html.Raw(Json.Serialize(Model.FuelTypeChart.Select(f => f.Amount))),
                backgroundColor: ['#0d6efd', '#198754', '#ffc107']
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false
        }
    });

    // Current date range for seamless refresh
    window.escaleDashboardStartDate = '@startDate.ToString("yyyy-MM-dd")';
    window.escaleDashboardEndDate = '@endDate.ToString("yyyy-MM-dd")';
</script>
}
