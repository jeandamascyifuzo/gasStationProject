    // ========================
    // DataTables Pagination
    // ========================

    var _dataTables = {};

    function initDataTable(tableId, options) {
        if (_dataTables[tableId]) {
            _dataTables[tableId].destroy();
            _dataTables[tableId] = null;
        }
        var defaults = {
            pageLength: 10,
            lengthChange: true,
            lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, 'All']],
            ordering: true,
            searching: true,
            info: true,
            stateSave: true,
            language: {
                search: '<i class="fas fa-search me-1"></i>',
                searchPlaceholder: 'Filter...',
                lengthMenu: 'Show _MENU_ entries',
                info: 'Showing _START_ to _END_ of _TOTAL_',
                paginate: { previous: '<i class="fas fa-chevron-left"></i>', next: '<i class="fas fa-chevron-right"></i>' }
            },
            dom: '<"row mb-2"<"col-sm-6"l><"col-sm-6"f>>rtip'
        };
        _dataTables[tableId] = $('#' + tableId).DataTable($.extend(defaults, options || {}));
    }

    // ========================
    // Chart.js Rendering
    // ========================

    function renderSalesTrendChart(dailySales) {
        var ctx = document.getElementById('salesTrendChart');
        if (!ctx) return;
        if (salesTrendChart) salesTrendChart.destroy();

        salesTrendChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: dailySales.map(function(d) { return fmtDate(d.Date); }),
                datasets: [{
                    label: 'Sales (RWF)',
                    data: dailySales.map(function(d) { return d.Amount; }),
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { callback: function(v) { return fmt(v); } }
                    }
                }
            }
        });
    }

    function renderFuelTypePieChart(salesByFuel) {
        var ctx = document.getElementById('fuelTypeChart');
        if (!ctx) return;
        if (fuelTypePieChart) fuelTypePieChart.destroy();

        fuelTypePieChart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: salesByFuel.map(function(d) { return d.FuelType; }),
                datasets: [{
                    data: salesByFuel.map(function(d) { return d.Amount; }),
                    backgroundColor: chartColors.slice(0, salesByFuel.length)
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 12 } }
                }
            }
        });
    }

    function renderFinancialTrendChart(dailyRevenue) {
        var ctx = document.getElementById('financialTrendChart');
        if (!ctx) return;
        if (financialTrendChart) financialTrendChart.destroy();

        financialTrendChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: dailyRevenue.map(function(d) { return fmtDate(d.Date); }),
                datasets: [{
                    label: 'Revenue (RWF)',
                    data: dailyRevenue.map(function(d) { return d.Amount; }),
                    backgroundColor: 'rgba(25, 135, 84, 0.7)',
                    borderColor: '#198754',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { callback: function(v) { return fmt(v); } }
                    }
                }
            }
        });
    }

    // ========================
    // Export
    // ========================

    function exportReport() {
        var startDate = $('#startDate').val();
        var endDate = $('#endDate').val();
        var reportType = $('#reportType').val();
        var stationId = $('#stationFilter').val();

        if (!startDate || !endDate) {
            showToast('Please select a date range before exporting.', 'error');
            return;
        }

        var url = '@Url.Action("ExportReport", "Reports")' +
            '?reportType=' + reportType +
            '&startDate=' + startDate +
            '&endDate=' + endDate;
        if (stationId) url += '&stationId=' + stationId;

        exportCsv(url, document.getElementById('exportBtn'), reportType + '_report.csv');
    }

    // ========================
    // Page Init
    // ========================

    $(document).ready(function() {
        // Quick date range buttons
        $('#quickDateBtns button').on('click', function() {
            $('#quickDateBtns button').removeClass('btn-primary active').addClass('btn-outline-secondary');
            $(this).removeClass('btn-outline-secondary').addClass('btn-primary active');

            var range = $(this).data('range');
            var now = new Date();
            var start = new Date();
            var end = new Date();

            switch(range) {
                case 'today':
                    break;
                case 'yesterday':
                    start.setDate(now.getDate() - 1);
                    end.setDate(now.getDate() - 1);
                    break;
                case 'week':
                    start.setDate(now.getDate() - 7);
                    break;
                case 'month':
                    start.setDate(now.getDate() - 30);
                    break;
                case 'custom':
                    return;
            }

            $('#startDate').val(start.toISOString().slice(0, 10));
            $('#endDate').val(end.toISOString().slice(0, 10));
            generateReport();
        });

        // Re-adjust DataTables columns when a tab becomes visible
        $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function(e) {
            var pane = $($(e.target).data('bs-target'));
            pane.find('table').each(function() {
                var id = $(this).attr('id');
                if (_dataTables[id]) {
                    _dataTables[id].columns.adjust();
                }
            });
        });

        // Auto-load today's report on page load
        generateReport();
    });
</script>
