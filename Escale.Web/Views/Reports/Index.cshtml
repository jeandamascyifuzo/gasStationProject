@model Escale.Web.Models.ReportViewModel
@{
    ViewData["Title"] = "Reports";
}

@await Html.PartialAsync("_ApiError")

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 page-header">
    <div>
        <h1 class="h2"><i class="fas fa-chart-bar me-2"></i>Reports & Analytics</h1>
        <p class="text-muted mb-0">Generate comprehensive reports and analyze business performance.</p>
    </div>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button type="button" class="btn btn-success" id="exportBtn" onclick="exportReport()">
            <i class="fas fa-file-excel me-2"></i>Export CSV
        </button>
    </div>
</div>

<!-- Report Filters -->
<div class="card shadow mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Report Filters</h5>
    </div>
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-12">
                <label class="form-label mb-1">Quick Range</label>
                <div class="btn-group" id="quickDateBtns">
                    <button type="button" class="btn btn-sm btn-primary active" data-range="today">Today</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-range="yesterday">Yesterday</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-range="week">This Week</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-range="month">This Month</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-range="custom">Custom</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-3 mb-3">
                <label for="reportType" class="form-label">Report Type</label>
                <select class="form-select" id="reportType" onchange="changeReportType()">
                    <option value="Sales">Sales Report</option>
                    <option value="Inventory">Inventory Report</option>
                    <option value="Employee">Employee Performance</option>
                    <option value="Customer">Customer Report</option>
                    <option value="Financial">Financial Report</option>
                </select>
            </div>
            <div class="col-md-2 mb-3">
                <label for="startDate" class="form-label">Start Date</label>
                <input type="date" class="form-control" id="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" onchange="generateReport()" />
            </div>
            <div class="col-md-2 mb-3">
                <label for="endDate" class="form-label">End Date</label>
                <input type="date" class="form-control" id="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" onchange="generateReport()" />
            </div>
            <div class="col-md-3 mb-3" id="stationFilterGroup">
                <label for="stationFilter" class="form-label">Station</label>
                <select class="form-select" id="stationFilter" onchange="generateReport()">
                    <option value="">All Stations</option>
                    @foreach (var station in Model.Stations)
                    {
                        <option value="@station.Id">@station.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2 mb-3" id="fuelTypeFilter">
                <label for="fuelType" class="form-label">Fuel Type</label>
                <select class="form-select" id="fuelType" onchange="generateReport()">
                    <option value="">All Fuel Types</option>
                    @foreach (var fuel in Model.FuelTypes)
                    {
                        <option value="@fuel.Id">@fuel.Name</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Report Display Area -->
<div class="card shadow">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0" id="reportTitle"><i class="fas fa-chart-line me-2"></i>Sales Report</h5>
        <small class="text-muted" id="reportTimestamp"></small>
    </div>
    <div class="card-body">
        <!-- Loading Indicator -->
        <div id="reportLoading" style="display: none;" class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Generating report...</p>
        </div>

        <!-- Sales Report -->
        <div id="salesReport">
            <div id="salesReportContent" style="display: none;">
                <!-- Summary Cards -->
                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="card bg-primary text-white">
                            <div class="card-body text-center">
                                <h6>Total Sales</h6>
                                <h3 id="summaryTotalSales">0 RWF</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-success text-white">
                            <div class="card-body text-center">
                                <h6>Transactions</h6>
                                <h3 id="summaryTransactionCount">0</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-info text-white">
                            <div class="card-body text-center">
                                <h6>Period</h6>
                                <h3 id="summaryPeriod" style="font-size: 0.9rem;">-</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sales Tabs -->
                <ul class="nav nav-tabs mb-3" id="salesTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="salesChartTab" data-bs-toggle="tab" data-bs-target="#salesChartPane" type="button" role="tab"><i class="fas fa-chart-line me-1"></i>Charts</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="salesFuelTab" data-bs-toggle="tab" data-bs-target="#salesFuelPane" type="button" role="tab"><i class="fas fa-gas-pump me-1"></i>By Fuel Type</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="salesPaymentTab" data-bs-toggle="tab" data-bs-target="#salesPaymentPane" type="button" role="tab"><i class="fas fa-credit-card me-1"></i>By Payment</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="salesDailyTab" data-bs-toggle="tab" data-bs-target="#salesDailyPane" type="button" role="tab"><i class="fas fa-calendar-day me-1"></i>Daily Sales</button>
                    </li>
                </ul>
                <div class="tab-content" id="salesTabContent">
                    <!-- Charts Tab -->
                    <div class="tab-pane fade show active" id="salesChartPane" role="tabpanel">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="card">
                                    <div class="card-header"><h6 class="mb-0">Daily Sales Trend</h6></div>
                                    <div class="card-body" style="height: 300px;">
                                        <canvas id="salesTrendChart"></canvas>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-header"><h6 class="mb-0">Sales by Fuel Type</h6></div>
                                    <div class="card-body" style="height: 300px;">
                                        <canvas id="fuelTypeChart"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- By Fuel Type Tab -->
                    <div class="tab-pane fade" id="salesFuelPane" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" id="salesByFuelTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Fuel Type</th>
                                        <th class="text-end">Liters</th>
                                        <th class="text-end">Amount (RWF)</th>
                                        <th class="text-center">Transactions</th>
                                    </tr>
                                </thead>
                                <tbody id="salesByFuelBody"></tbody>
                                <tfoot id="salesByFuelFoot" class="table-light fw-bold"></tfoot>
                            </table>
                        </div>
                    </div>
                    <!-- By Payment Tab -->
                    <div class="tab-pane fade" id="salesPaymentPane" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" id="salesByPaymentTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Payment Method</th>
                                        <th class="text-end">Amount (RWF)</th>
                                        <th class="text-center">Transactions</th>
                                    </tr>
                                </thead>
                                <tbody id="salesByPaymentBody"></tbody>
                            </table>
                        </div>
                    </div>
                    <!-- Daily Sales Tab -->
                    <div class="tab-pane fade" id="salesDailyPane" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" id="dailySalesTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th class="text-end">Amount (RWF)</th>
                                        <th class="text-center">Transactions</th>
                                    </tr>
                                </thead>
                                <tbody id="dailySalesBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Inventory Report -->
        <div id="inventoryReport" style="display: none;">
            <div id="inventoryReportContent" style="display: none;">
                <!-- Inventory Summary Cards -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card bg-success text-white">
                            <div class="card-body text-center">
                                <h6>Normal</h6>
                                <h3 id="invNormalCount">0</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-warning text-dark">
                            <div class="card-body text-center">
                                <h6>Low Stock</h6>
                                <h3 id="invLowCount">0</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-danger text-white">
                            <div class="card-body text-center">
                                <h6>Critical</h6>
                                <h3 id="invCriticalCount">0</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-primary text-white">
                            <div class="card-body text-center">
                                <h6>Total Refill Cost</h6>
                                <h3 id="invTotalRefillCost">0 RWF</h3>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="inventoryTable">
                        <thead class="table-light">
                            <tr>
                                <th>Station</th>
                                <th>Fuel Type</th>
                                <th class="text-end">Current Level (L)</th>
                                <th class="text-end">Capacity (L)</th>
                                <th class="text-center">% Full</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Refill Count</th>
                                <th class="text-end">Refill Cost (RWF)</th>
                            </tr>
                        </thead>
                        <tbody id="inventoryTableBody"></tbody>
                    </table>
                </div>
            </div>
            <div id="inventoryEmpty" class="alert alert-warning" style="display: none;">
                <i class="fas fa-exclamation-triangle me-2"></i>No inventory data found.
            </div>
        </div>

        <!-- Employee Report -->
        <div id="employeeReport" style="display: none;">
            <div id="employeeReportContent" style="display: none;">
                <!-- Employee Summary Cards -->
                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="card bg-primary text-white">
                            <div class="card-body text-center">
                                <h6>Total Employees</h6>
                                <h3 id="empTotalCount">0</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-success text-white">
                            <div class="card-body text-center">
                                <h6>Total Sales</h6>
                                <h3 id="empTotalSales">0 RWF</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-info text-white">
                            <div class="card-body text-center">
                                <h6>Total Shifts</h6>
                                <h3 id="empTotalShifts">0</h3>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="employeeTable">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th class="text-center">Role</th>
                                <th class="text-center">Transactions</th>
                                <th class="text-end">Total Sales (RWF)</th>
                                <th class="text-center">Shifts</th>
                                <th class="text-end">Hours Worked</th>
                            </tr>
                        </thead>
                        <tbody id="employeeTableBody"></tbody>
                    </table>
                </div>
            </div>
            <div id="employeeEmpty" class="alert alert-warning" style="display: none;">
                <i class="fas fa-exclamation-triangle me-2"></i>No employee data found for this period.
            </div>
        </div>

        <!-- Customer Report -->
        <div id="customerReport" style="display: none;">
            <div id="customerReportContent" style="display: none;">
                <!-- Customer Summary Cards -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card bg-primary text-white">
                            <div class="card-body text-center">
                                <h6>Total Customers</h6>
                                <h3 id="custTotalCount">0</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-success text-white">
                            <div class="card-body text-center">
                                <h6>Total Spent</h6>
                                <h3 id="custTotalSpent">0 RWF</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-info text-white">
                            <div class="card-body text-center">
                                <h6>Total Liters</h6>
                                <h3 id="custTotalLiters">0</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-warning text-dark">
                            <div class="card-body text-center">
                                <h6>Avg. per Customer</h6>
                                <h3 id="custAvgSpent">0 RWF</h3>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="customerTable">
                        <thead class="table-light">
                            <tr>
                                <th>Customer</th>
                                <th class="text-center">Type</th>
                                <th class="text-center">Status</th>
                                <th>Email</th>
                                <th>TIN</th>
                                <th class="text-center">Cars</th>
                                <th class="text-center">Subs</th>
                                <th class="text-center">Transactions</th>
                                <th class="text-end">Total Spent (RWF)</th>
                                <th class="text-end">Total Liters</th>
                                <th class="text-end">Remaining Balance (RWF)</th>
                            </tr>
                        </thead>
                        <tbody id="customerTableBody"></tbody>
                    </table>
                </div>
            </div>
            <div id="customerEmpty" class="alert alert-warning" style="display: none;">
                <i class="fas fa-exclamation-triangle me-2"></i>No customer data found for this period.
            </div>
        </div>

        <!-- Financial Report -->
        <div id="financialReport" style="display: none;">
            <div id="financialReportContent" style="display: none;">
                <!-- Financial Summary Cards -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card bg-success text-white">
                            <div class="card-body text-center">
                                <h6>Total Revenue</h6>
                                <h3 id="finTotalRevenue">0 RWF</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-warning text-dark">
                            <div class="card-body text-center">
                                <h6>Total VAT</h6>
                                <h3 id="finTotalVAT">0 RWF</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-danger text-white">
                            <div class="card-body text-center">
                                <h6>Refill Cost</h6>
                                <h3 id="finRefillCost">0 RWF</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-primary text-white">
                            <div class="card-body text-center">
                                <h6>Gross Profit</h6>
                                <h3 id="finGrossProfit">0 RWF</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Financial Tabs -->
                <ul class="nav nav-tabs mb-3" id="financialTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="finChartTab" data-bs-toggle="tab" data-bs-target="#finChartPane" type="button" role="tab"><i class="fas fa-chart-bar me-1"></i>Revenue Chart</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="finTableTab" data-bs-toggle="tab" data-bs-target="#finTablePane" type="button" role="tab"><i class="fas fa-table me-1"></i>Daily Revenue</button>
                    </li>
                </ul>
                <div class="tab-content" id="financialTabContent">
                    <!-- Chart Tab -->
                    <div class="tab-pane fade show active" id="finChartPane" role="tabpanel">
                        <div class="card">
                            <div class="card-body" style="height: 300px;">
                                <canvas id="financialTrendChart"></canvas>
                            </div>
                        </div>
                    </div>
                    <!-- Table Tab -->
                    <div class="tab-pane fade" id="finTablePane" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" id="financialTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th class="text-end">Amount (RWF)</th>
                                        <th class="text-center">Transactions</th>
                                    </tr>
                                </thead>
                                <tbody id="financialTableBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div id="financialEmpty" class="alert alert-warning" style="display: none;">
                <i class="fas fa-exclamation-triangle me-2"></i>No financial data found for this period.
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Chart instances
    var salesTrendChart = null;
    var fuelTypePieChart = null;
    var financialTrendChart = null;

    var chartColors = ['#0d6efd', '#198754', '#ffc107', '#dc3545', '#0dcaf0', '#6f42c1', '#fd7e14', '#20c997'];

    // showToast is now global from site.js

    function fmt(num) {
        return Number(num).toLocaleString('en-US');
    }

    function fmtDate(dateStr) {
        return new Date(dateStr).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    function changeReportType() {
        var reportType = $('#reportType').val();

        $('#salesReport, #inventoryReport, #employeeReport, #customerReport, #financialReport').hide();

        switch(reportType) {
            case 'Sales':
                $('#reportTitle').html('<i class="fas fa-chart-line me-2"></i>Sales Report');
                $('#salesReport').show();
                $('#fuelTypeFilter').show();
                $('#stationFilterGroup').show();
                break;
            case 'Inventory':
                $('#reportTitle').html('<i class="fas fa-boxes me-2"></i>Inventory Report');
                $('#inventoryReport').show();
                $('#fuelTypeFilter').hide();
                $('#stationFilterGroup').show();
                break;
            case 'Employee':
                $('#reportTitle').html('<i class="fas fa-users me-2"></i>Employee Performance Report');
                $('#employeeReport').show();
                $('#fuelTypeFilter').hide();
                $('#stationFilterGroup').hide();
                break;
            case 'Customer':
                $('#reportTitle').html('<i class="fas fa-user-friends me-2"></i>Customer Report');
                $('#customerReport').show();
                $('#fuelTypeFilter').hide();
                $('#stationFilterGroup').hide();
                break;
            case 'Financial':
                $('#reportTitle').html('<i class="fas fa-dollar-sign me-2"></i>Financial Report');
                $('#financialReport').show();
                $('#fuelTypeFilter').hide();
                $('#stationFilterGroup').hide();
                break;
        }

        generateReport();
    }

    var _reportRequest = null;

    function generateReport() {
        var reportType = $('#reportType').val();
        var startDate = $('#startDate').val();
        var endDate = $('#endDate').val();
        var stationId = $('#stationFilter').val();

        // Abort previous request if still in progress
        if (_reportRequest && _reportRequest.readyState !== 4) {
            _reportRequest.abort();
        }

        $('#reportLoading').show();

        var done = function() {
            $('#reportLoading').hide();
            $('#reportTimestamp').text('Generated: ' + new Date().toLocaleTimeString());
        };

        switch(reportType) {
            case 'Sales':
                generateSalesReport(startDate, endDate, stationId, done);
                break;
            case 'Inventory':
                generateInventoryReport(stationId, done);
                break;
            case 'Employee':
                generateEmployeeReport(startDate, endDate, done);
                break;
            case 'Customer':
                generateCustomerReport(startDate, endDate, done);
                break;
            case 'Financial':
                generateFinancialReport(startDate, endDate, done);
                break;
        }
    }

    var _salesTableIds = ['salesByFuelTable', 'salesByPaymentTable', 'dailySalesTable'];

    function generateSalesReport(startDate, endDate, stationId, done) {
        _salesTableIds.forEach(function(id) { if (_dataTables[id]) { _dataTables[id].destroy(); _dataTables[id] = null; } });
        $('#salesReportContent').hide();
        _reportRequest = $.get('@Url.Action("GenerateSalesReport", "Reports")',
            { startDate: startDate, endDate: endDate, stationId: stationId },
            function(data) {
                if (!data || data.TransactionCount === 0) {
                    showToast('No sales data found for this period.', 'info');
                    return;
                }

                // Summary
                $('#summaryTotalSales').text(fmt(data.TotalSales) + ' RWF');
                $('#summaryTransactionCount').text(fmt(data.TransactionCount));
                var start = fmtDate(data.StartDate);
                var end = fmtDate(data.EndDate);
                $('#summaryPeriod').text(start + ' - ' + end);

                // Sales by Fuel Type table
                $('#salesByFuelBody').empty();
                $('#salesByFuelFoot').empty();
                if (data.SalesByFuel && data.SalesByFuel.length > 0) {
                    var totalLiters = 0, totalAmount = 0, totalTxn = 0;
                    data.SalesByFuel.forEach(function(item) {
                        totalLiters += item.Liters;
                        totalAmount += item.Amount;
                        totalTxn += item.TransactionCount;
                        $('#salesByFuelBody').append(
                            '<tr>' +
                            '<td><span class="badge bg-primary">' + item.FuelType + '</span></td>' +
                            '<td class="text-end">' + fmt(item.Liters) + '</td>' +
                            '<td class="text-end">' + fmt(item.Amount) + '</td>' +
                            '<td class="text-center">' + fmt(item.TransactionCount) + '</td>' +
                            '</tr>'
                        );
                    });
                    $('#salesByFuelFoot').append(
                        '<tr><td>Total</td><td class="text-end">' + fmt(totalLiters) + '</td>' +
                        '<td class="text-end">' + fmt(totalAmount) + '</td>' +
                        '<td class="text-center">' + fmt(totalTxn) + '</td></tr>'
                    );
                }

                // Sales by Payment Method table
                $('#salesByPaymentBody').empty();
                if (data.SalesByPayment && data.SalesByPayment.length > 0) {
                    var paymentBadges = { 'Cash': 'bg-secondary', 'MobileMoney': 'bg-success', 'Card': 'bg-primary', 'Credit': 'bg-danger' };
                    var paymentLabels = { 'Cash': 'Cash', 'MobileMoney': 'Mobile Money', 'Card': 'Card', 'Credit': 'Credit' };
                    data.SalesByPayment.forEach(function(item) {
                        var badge = paymentBadges[item.PaymentMethod] || 'bg-secondary';
                        var label = paymentLabels[item.PaymentMethod] || item.PaymentMethod;
                        $('#salesByPaymentBody').append(
                            '<tr>' +
                            '<td><span class="badge ' + badge + '">' + label + '</span></td>' +
                            '<td class="text-end">' + fmt(item.Amount) + '</td>' +
                            '<td class="text-center">' + fmt(item.TransactionCount) + '</td>' +
                            '</tr>'
                        );
                    });
                }

                // Daily Sales table
                $('#dailySalesBody').empty();
                if (data.DailySales && data.DailySales.length > 0) {
                    data.DailySales.forEach(function(item) {
                        $('#dailySalesBody').append(
                            '<tr>' +
                            '<td>' + fmtDate(item.Date) + '</td>' +
                            '<td class="text-end">' + fmt(item.Amount) + '</td>' +
                            '<td class="text-center">' + item.TransactionCount + '</td>' +
                            '</tr>'
                        );
                    });
                }

                // Sales Trend Chart
                renderSalesTrendChart(data.DailySales || []);

                // Fuel Type Pie Chart
                renderFuelTypePieChart(data.SalesByFuel || []);

                $('#salesReportContent').show();
                _salesTableIds.forEach(function(id) { initDataTable(id); });
            }
        ).fail(function(xhr) {
            showToast('Failed to load sales report. ' + (xhr.status === 401 ? 'Please login again.' : ''), 'error');
        }).always(function() { if (done) done(); });
    }

    function generateInventoryReport(stationId, done) {
        if (_dataTables['inventoryTable']) { _dataTables['inventoryTable'].destroy(); _dataTables['inventoryTable'] = null; }
        $('#inventoryReportContent, #inventoryEmpty').hide();
        _reportRequest = $.get('@Url.Action("GenerateInventoryReport", "Reports")',
            { stationId: stationId },
            function(data) {
                $('#inventoryTableBody').empty();
                if (!data || data.length === 0) {
                    $('#inventoryEmpty').show();
                    return;
                }

                var normalCount = 0, lowCount = 0, criticalCount = 0, totalRefill = 0;
                data.forEach(function(item) {
                    if (item.Status === 'Critical') criticalCount++;
                    else if (item.Status === 'Low Stock') lowCount++;
                    else normalCount++;
                    totalRefill += item.TotalRefillCost;

                    var statusClass = item.Status === 'Critical' ? 'bg-danger' :
                                      item.Status === 'Low Stock' ? 'bg-warning text-dark' : 'bg-success';

                    var pctBar = '<div class="progress" style="height: 20px;">' +
                        '<div class="progress-bar ' + (item.PercentageFull < 10 ? 'bg-danger' : item.PercentageFull < 25 ? 'bg-warning' : 'bg-success') +
                        '" style="width: ' + Math.min(item.PercentageFull, 100) + '%;">' +
                        Number(item.PercentageFull).toFixed(1) + '%</div></div>';

                    $('#inventoryTableBody').append(
                        '<tr>' +
                        '<td>' + item.StationName + '</td>' +
                        '<td><span class="badge bg-primary">' + item.FuelType + '</span></td>' +
                        '<td class="text-end">' + fmt(item.CurrentLevel) + '</td>' +
                        '<td class="text-end">' + fmt(item.Capacity) + '</td>' +
                        '<td>' + pctBar + '</td>' +
                        '<td class="text-center"><span class="badge ' + statusClass + '">' + item.Status + '</span></td>' +
                        '<td class="text-center">' + item.RefillCount + '</td>' +
                        '<td class="text-end">' + fmt(item.TotalRefillCost) + '</td>' +
                        '</tr>'
                    );
                });

                $('#invNormalCount').text(normalCount);
                $('#invLowCount').text(lowCount);
                $('#invCriticalCount').text(criticalCount);
                $('#invTotalRefillCost').text(fmt(totalRefill) + ' RWF');

                $('#inventoryReportContent').show();
                initDataTable('inventoryTable');
            }
        ).fail(function(xhr) {
            showToast('Failed to load inventory report. ' + (xhr.status === 401 ? 'Please login again.' : ''), 'error');
        }).always(function() { if (done) done(); });
    }

