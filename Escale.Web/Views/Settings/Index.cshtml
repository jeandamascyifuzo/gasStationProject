@model Escale.Web.Models.SettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-4 page-header">
    <div>
        <h1 class="h2"><i class="fas fa-cog me-2"></i>System Settings</h1>
        <p class="text-muted mb-0">Configure your system preferences and company information.</p>
    </div>
</div>

@await Html.PartialAsync("_ApiError")

<!-- Tabs -->
<div class="card shadow">
    <div class="card-header bg-dark">
        <ul class="nav nav-tabs card-header-tabs" id="settingsTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active text-white" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button" role="tab">
                    <i class="fas fa-sliders-h me-2"></i>General Settings
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link text-white" id="ebm-tab" data-bs-toggle="tab" data-bs-target="#ebm" type="button" role="tab">
                    <i class="fas fa-plug me-2"></i>EBM Settings
                </button>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <form asp-controller="Settings" asp-action="UpdateSettings" method="post" id="settingsForm" data-loading-form>
            <div class="tab-content" id="settingsTabsContent">

                <!-- General Settings Tab -->
                <div class="tab-pane fade show active" id="general" role="tabpanel">
                    <h5 class="mb-3">Company Information</h5>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="companyName" class="form-label">Company Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="companyName" name="CompanyName" value="@Model.CompanyName" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label for="currency" class="form-label">Currency</label>
                            <select class="form-select" id="currency" name="Currency">
                                <option value="RWF" selected="@(Model.Currency == "RWF")">RWF - Rwandan Franc</option>
                                <option value="USD" selected="@(Model.Currency == "USD")">USD - US Dollar</option>
                                <option value="EUR" selected="@(Model.Currency == "EUR")">EUR - Euro</option>
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label for="taxRate" class="form-label">Tax Rate (%)</label>
                            <input type="number" class="form-control" id="taxRate" name="TaxRate" value="@Model.TaxRate" step="0.01" min="0" max="100" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="receiptHeader" class="form-label">Receipt Header</label>
                            <textarea class="form-control" id="receiptHeader" name="ReceiptHeader" rows="2" placeholder="Text printed at the top of receipts">@Model.ReceiptHeader</textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="receiptFooter" class="form-label">Receipt Footer</label>
                            <textarea class="form-control" id="receiptFooter" name="ReceiptFooter" rows="2" placeholder="Text printed at the bottom of receipts">@Model.ReceiptFooter</textarea>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <h5 class="mb-3">Sales & Inventory</h5>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="minimumSaleAmount" class="form-label">Minimum Sale Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">@Model.Currency</span>
                                <input type="number" class="form-control" id="minimumSaleAmount" name="MinimumSaleAmount" value="@Model.MinimumSaleAmount" step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="maximumSaleAmount" class="form-label">Maximum Sale Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">@Model.Currency</span>
                                <input type="number" class="form-control" id="maximumSaleAmount" name="MaximumSaleAmount" value="@Model.MaximumSaleAmount" step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="lowStockThreshold" class="form-label">Low Stock Threshold</label>
                            <input type="number" class="form-control" id="lowStockThreshold" name="LowStockThreshold" value="@Model.LowStockThreshold" step="0.01" min="0" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="criticalStockThreshold" class="form-label">Critical Stock Threshold</label>
                            <input type="number" class="form-control" id="criticalStockThreshold" name="CriticalStockThreshold" value="@Model.CriticalStockThreshold" step="0.01" min="0" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="allowNegativeStock" name="AllowNegativeStock" value="true" @(Model.AllowNegativeStock ? "checked" : "") />
                                <label class="form-check-label" for="allowNegativeStock">
                                    Allow Negative Stock
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="autoPrintReceipt" name="AutoPrintReceipt" value="true" @(Model.AutoPrintReceipt ? "checked" : "") />
                                <label class="form-check-label" for="autoPrintReceipt">
                                    Auto-Print Receipt
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="requireCustomerInfo" name="RequireCustomerInfo" value="true" @(Model.RequireCustomerInfo ? "checked" : "") />
                                <label class="form-check-label" for="requireCustomerInfo">
                                    Require Customer Info
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- EBM Settings Tab -->
                <div class="tab-pane fade" id="ebm" role="tabpanel">
                    <h5 class="mb-3">
                        EBM Integration
                        @if (Model.EBMIsConfigured)
                        {
                            <span class="badge bg-success ms-2">Configured</span>
                        }
                        else if (Model.EBMEnabled)
                        {
                            <span class="badge bg-warning ms-2">Incomplete</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary ms-2">Disabled</span>
                        }
                    </h5>

                    <!-- Connection Status -->
                    <div class="row mb-4">
                        <div class="col-md-10">
                            <div class="card @(Model.EBMIsConfigured ? "border-success" : "border-warning")">
                                <div class="card-body d-flex align-items-center">
                                    <div class="me-3">
                                        <i class="fas @(Model.EBMIsConfigured ? "fa-check-circle text-success" : "fa-exclamation-triangle text-warning") fa-2x"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1">EBM Status: <strong>@Model.EBMStatus</strong></h6>
                                        <small class="text-muted">
                                            @(Model.EBMEnabled ? "EBM is enabled for this organization" : "EBM is not enabled")
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (Model.EBMEnabled)
                    {
                        <!-- EBM Configuration (Read-Only) -->
                        <h6 class="mb-3 text-muted"><i class="fas fa-lock me-1"></i>Configuration (managed by SuperAdmin)</h6>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Server URL</label>
                                <input type="text" class="form-control" value="@(Model.EBMServerUrl ?? "Not set")" readonly disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Company Name</label>
                                <input type="text" class="form-control" value="@(Model.EBMCompanyName ?? "Not set")" readonly disabled />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Company TIN</label>
                                <input type="text" class="form-control" value="@(Model.EBMCompanyTIN ?? "Not set")" readonly disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Company Phone</label>
                                <input type="text" class="form-control" value="@(Model.EBMCompanyPhone ?? "Not set")" readonly disabled />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Company Address</label>
                                <input type="text" class="form-control" value="@(Model.EBMCompanyAddress ?? "Not set")" readonly disabled />
                            </div>
                        </div>

                        <div class="alert alert-info mt-3">
                            <i class="fas fa-info-circle me-2"></i>
                            EBM integration sends transaction data to the Rwanda Revenue Authority for tax compliance.
                            All sales will automatically generate EBM receipts. Contact your SuperAdmin to modify EBM settings.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mt-3">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            EBM is not enabled for your organization. Contact your SuperAdmin to configure EBM integration.
                        </div>
                    }
                </div>

            </div>

            <!-- Save button (applies to General and EBM tabs) -->
            <div class="mt-4 pt-3 border-top" id="saveButtonSection">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Save Settings
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    // Show/hide save button based on active tab
    document.addEventListener('DOMContentLoaded', function () {
        var settingsTabs = document.getElementById('settingsTabs');
        var saveSection = document.getElementById('saveButtonSection');

        settingsTabs.addEventListener('shown.bs.tab', function (event) {
            // Hide save button on EBM tab (read-only)
            if (event.target.id === 'ebm-tab') {
                saveSection.style.display = 'none';
            } else {
                saveSection.style.display = '';
            }
        });
    });
</script>
}
