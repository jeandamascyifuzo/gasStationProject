@model Escale.Web.Models.SettingsViewModel
@{
    ViewData["Title"] = "Settings";
    var apiBaseUrl = ((Microsoft.Extensions.Options.IOptions<Escale.Web.Configuration.ApiSettings>)
        Context.RequestServices.GetService(typeof(Microsoft.Extensions.Options.IOptions<Escale.Web.Configuration.ApiSettings>)))?.Value?.BaseUrl ?? "https://localhost:7015/api";
    var fullLogoUrl = !string.IsNullOrEmpty(Model.LogoUrl) ? apiBaseUrl.Replace("/api", "") + Model.LogoUrl : "";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-4 page-header">
    <div>
        <h1 class="h2"><i class="fas fa-cog me-2"></i>System Settings</h1>
        <p class="text-muted mb-0">Configure your system preferences and company information.</p>
    </div>
</div>

@await Html.PartialAsync("_ApiError")

<!-- Tabs -->
<div class="card shadow">
    <div class="card-header bg-dark">
        <ul class="nav nav-tabs card-header-tabs" id="settingsTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active text-white" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button" role="tab">
                    <i class="fas fa-sliders-h me-2"></i>General Settings
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link text-white" id="branding-tab" data-bs-toggle="tab" data-bs-target="#branding" type="button" role="tab">
                    <i class="fas fa-image me-2"></i>Company Logo
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link text-white" id="payment-tab" data-bs-toggle="tab" data-bs-target="#payment" type="button" role="tab">
                    <i class="fas fa-credit-card me-2"></i>Payment Methods
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link text-white" id="ebm-tab" data-bs-toggle="tab" data-bs-target="#ebm" type="button" role="tab">
                    <i class="fas fa-plug me-2"></i>EBM Settings
                </button>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <form asp-controller="Settings" asp-action="UpdateSettings" method="post" id="settingsForm" data-loading-form>
            <div class="tab-content" id="settingsTabsContent">

                <!-- General Settings Tab -->
                <div class="tab-pane fade show active" id="general" role="tabpanel">
                    <h5 class="mb-3">Company Information</h5>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="companyName" class="form-label">Company Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="companyName" name="CompanyName" value="@Model.CompanyName" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label for="currency" class="form-label">Currency</label>
                            <select class="form-select" id="currency" name="Currency">
                                <option value="RWF" selected="@(Model.Currency == "RWF")">RWF - Rwandan Franc</option>
                                <option value="USD" selected="@(Model.Currency == "USD")">USD - US Dollar</option>
                                <option value="EUR" selected="@(Model.Currency == "EUR")">EUR - Euro</option>
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label for="taxRate" class="form-label">Tax Rate (%)</label>
                            <input type="number" class="form-control" id="taxRate" name="TaxRate" value="@Model.TaxRate" step="0.01" min="0" max="100" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="receiptHeader" class="form-label">Receipt Header</label>
                            <textarea class="form-control" id="receiptHeader" name="ReceiptHeader" rows="2" placeholder="Text printed at the top of receipts">@Model.ReceiptHeader</textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="receiptFooter" class="form-label">Receipt Footer</label>
                            <textarea class="form-control" id="receiptFooter" name="ReceiptFooter" rows="2" placeholder="Text printed at the bottom of receipts">@Model.ReceiptFooter</textarea>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <h5 class="mb-3">Sales & Inventory</h5>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="minimumSaleAmount" class="form-label">Minimum Sale Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">@Model.Currency</span>
                                <input type="number" class="form-control" id="minimumSaleAmount" name="MinimumSaleAmount" value="@Model.MinimumSaleAmount" step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="maximumSaleAmount" class="form-label">Maximum Sale Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">@Model.Currency</span>
                                <input type="number" class="form-control" id="maximumSaleAmount" name="MaximumSaleAmount" value="@Model.MaximumSaleAmount" step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="lowStockThreshold" class="form-label">Low Stock Threshold</label>
                            <input type="number" class="form-control" id="lowStockThreshold" name="LowStockThreshold" value="@Model.LowStockThreshold" step="0.01" min="0" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="criticalStockThreshold" class="form-label">Critical Stock Threshold</label>
                            <input type="number" class="form-control" id="criticalStockThreshold" name="CriticalStockThreshold" value="@Model.CriticalStockThreshold" step="0.01" min="0" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="allowNegativeStock" name="AllowNegativeStock" value="true" @(Model.AllowNegativeStock ? "checked" : "") />
                                <label class="form-check-label" for="allowNegativeStock">
                                    Allow Negative Stock
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="autoPrintReceipt" name="AutoPrintReceipt" value="true" @(Model.AutoPrintReceipt ? "checked" : "") />
                                <label class="form-check-label" for="autoPrintReceipt">
                                    Auto-Print Receipt
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="requireCustomerInfo" name="RequireCustomerInfo" value="true" @(Model.RequireCustomerInfo ? "checked" : "") />
                                <label class="form-check-label" for="requireCustomerInfo">
                                    Require Customer Info
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Company Logo Tab -->
                <div class="tab-pane fade" id="branding" role="tabpanel">
                    <h5 class="mb-3">Company Logo</h5>
                    <p class="text-muted mb-4">Upload your company logo. It will appear in the navigation bar and login screen.</p>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <div class="card border">
                                <div class="card-body text-center p-4">
                                    @if (!string.IsNullOrEmpty(fullLogoUrl))
                                    {
                                        <img src="@fullLogoUrl" alt="Company Logo" class="img-fluid mb-3" style="max-height: 120px; max-width: 200px; object-fit: contain;" />
                                        <p class="text-success mb-0"><i class="fas fa-check-circle me-1"></i>Logo uploaded</p>
                                    }
                                    else
                                    {
                                        <div class="text-muted py-4">
                                            <i class="fas fa-building fa-3x mb-3 d-block"></i>
                                            <p class="mb-0">No logo uploaded</p>
                                            <small>Your company name will be shown instead</small>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="col-md-8 mb-3">
                            <form asp-controller="Settings" asp-action="UploadLogo" method="post" enctype="multipart/form-data">
                                <div class="mb-3">
                                    <label for="logoFile" class="form-label">Select Logo Image</label>
                                    <input type="file" class="form-control" id="logoFile" name="logo" accept="image/jpeg,image/png,image/gif,image/webp" />
                                    <div class="form-text">Accepted formats: JPG, PNG, GIF, WebP. Maximum size: 2MB.</div>
                                </div>
                                <div id="logoPreviewContainer" class="mb-3" style="display:none;">
                                    <label class="form-label">Preview</label>
                                    <div>
                                        <img id="logoPreview" src="" alt="Preview" style="max-height: 80px; max-width: 160px; object-fit: contain; border: 1px solid #dee2e6; border-radius: 4px; padding: 4px;" />
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-upload me-2"></i>Upload Logo
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Payment Methods Tab -->
                <div class="tab-pane fade" id="payment" role="tabpanel">
                    <h5 class="mb-1">Payment Methods</h5>
                    <p class="text-muted mb-4">Enable or disable payment methods available to cashiers when processing sales.</p>

                    @if (!Model.PaymentMethods.Any())
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            No payment methods found. They are created automatically — try refreshing the page.
                        </div>
                    }
                    else
                    {
                        <div class="row">
                            @foreach (var pm in Model.PaymentMethods.OrderBy(p => p.SortOrder))
                            {
                                <div class="col-md-6 col-lg-4 mb-3">
                                    <div class="card h-100 border @(pm.IsEnabled ? "border-success" : "border-secondary")" id="pm-card-@pm.Id">
                                        <div class="card-body d-flex align-items-center gap-3">
                                            <div class="fs-3 text-@(pm.IsEnabled ? "success" : "secondary")">
                                                @if (pm.Name == "Cash") { <i class="fas fa-money-bill-wave"></i> }
                                                else if (pm.Name == "MobileMoney") { <i class="fas fa-mobile-alt"></i> }
                                                else if (pm.Name == "Card") { <i class="fas fa-credit-card"></i> }
                                                else if (pm.Name == "Credit") { <i class="fas fa-hand-holding-usd"></i> }
                                                else { <i class="fas fa-wallet"></i> }
                                            </div>
                                            <div class="flex-grow-1">
                                                <div class="fw-semibold" id="pm-name-@pm.Id">@pm.DisplayName</div>
                                                <small class="text-muted">@pm.Name</small>
                                            </div>
                                            <div class="form-check form-switch mb-0">
                                                <input class="form-check-input" type="checkbox" role="switch"
                                                       id="pm-toggle-@pm.Id"
                                                       @(pm.IsEnabled ? "checked" : "")
                                                       onchange="togglePaymentMethod('@pm.Id', '@pm.DisplayName', this.checked)" />
                                            </div>
                                        </div>
                                        <div class="card-footer bg-transparent py-2 px-3">
                                            <span class="badge @(pm.IsEnabled ? "bg-success" : "bg-secondary")" id="pm-badge-@pm.Id">
                                                @(pm.IsEnabled ? "Enabled" : "Disabled")
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="alert alert-info mt-2">
                            <i class="fas fa-info-circle me-2"></i>
                            Changes take effect immediately. Cashiers will only see enabled payment methods when processing sales.
                        </div>
                    }
                </div>

                <!-- EBM Settings Tab -->
                <div class="tab-pane fade" id="ebm" role="tabpanel">
                    <h5 class="mb-3">
                        EBM Integration
                        @if (Model.EBMIsConfigured)
                        {
                            <span class="badge bg-success ms-2">Configured</span>
                        }
                        else if (Model.EBMEnabled)
                        {
                            <span class="badge bg-warning ms-2">Incomplete</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary ms-2">Disabled</span>
                        }
                    </h5>

                    <!-- Connection Status -->
                    <div class="row mb-4">
                        <div class="col-md-10">
                            <div class="card @(Model.EBMIsConfigured ? "border-success" : "border-warning")">
                                <div class="card-body d-flex align-items-center">
                                    <div class="me-3">
                                        <i class="fas @(Model.EBMIsConfigured ? "fa-check-circle text-success" : "fa-exclamation-triangle text-warning") fa-2x"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1">EBM Status: <strong>@Model.EBMStatus</strong></h6>
                                        <small class="text-muted">
                                            @(Model.EBMEnabled ? "EBM is enabled for this organization" : "EBM is not enabled")
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (Model.EBMEnabled)
                    {
                        <!-- EBM Configuration (Read-Only) -->
                        <h6 class="mb-3 text-muted"><i class="fas fa-lock me-1"></i>Configuration (managed by SuperAdmin)</h6>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Server URL</label>
                                <input type="text" class="form-control" value="@(Model.EBMServerUrl ?? "Not set")" readonly disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Company Name</label>
                                <input type="text" class="form-control" value="@(Model.EBMCompanyName ?? "Not set")" readonly disabled />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Company TIN</label>
                                <input type="text" class="form-control" value="@(Model.EBMCompanyTIN ?? "Not set")" readonly disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Company Phone</label>
                                <input type="text" class="form-control" value="@(Model.EBMCompanyPhone ?? "Not set")" readonly disabled />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Company Address</label>
                                <input type="text" class="form-control" value="@(Model.EBMCompanyAddress ?? "Not set")" readonly disabled />
                            </div>
                        </div>

                        <div class="alert alert-info mt-3">
                            <i class="fas fa-info-circle me-2"></i>
                            EBM integration sends transaction data to the Rwanda Revenue Authority for tax compliance.
                            All sales will automatically generate EBM receipts. Contact your SuperAdmin to modify EBM settings.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mt-3">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            EBM is not enabled for your organization. Contact your SuperAdmin to configure EBM integration.
                        </div>
                    }
                </div>

            </div>

            <!-- Save button (applies to General and EBM tabs) -->
            <div class="mt-4 pt-3 border-top" id="saveButtonSection">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Save Settings
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var settingsTabs = document.getElementById('settingsTabs');
        var saveSection = document.getElementById('saveButtonSection');

        // Show/hide save button based on active tab
        settingsTabs.addEventListener('shown.bs.tab', function (event) {
            var noSaveTabs = ['ebm-tab', 'branding-tab', 'payment-tab'];
            saveSection.style.display = noSaveTabs.includes(event.target.id) ? 'none' : '';
        });

        // Logo preview
        var logoInput = document.getElementById('logoFile');

        if (logoInput) {
            logoInput.addEventListener('change', function (e) {
                var file = e.target.files[0];
                var preview = document.getElementById('logoPreview');
                var container = document.getElementById('logoPreviewContainer');
                if (file && file.type.startsWith('image/')) {
                    var reader = new FileReader();
                    reader.onload = function (ev) {
                        preview.src = ev.target.result;
                        container.style.display = '';
                    };
                    reader.readAsDataURL(file);
                } else {
                    container.style.display = 'none';
                }
            });
        }
    });

    function showConfirm(title, bodyHtml, confirmText, confirmClass) {
        return new Promise(resolve => {
            const modalEl = document.getElementById('pmConfirmModal');
            document.getElementById('pmConfirmTitle').textContent = title;
            document.getElementById('pmConfirmBody').innerHTML = bodyHtml;
            const btn = document.getElementById('pmConfirmBtn');
            btn.textContent = confirmText;
            btn.className = 'btn ' + confirmClass;

            const modal = new bootstrap.Modal(modalEl);
            let resolved = false;

            btn.onclick = () => { resolved = true; modal.hide(); resolve(true); };
            modalEl.addEventListener('hidden.bs.modal', () => { if (!resolved) resolve(false); }, { once: true });
            modal.show();
        });
    }

    async function togglePaymentMethod(id, displayName, isEnabled) {
        const toggle = document.getElementById('pm-toggle-' + id);
        const card = document.getElementById('pm-card-' + id);
        const badge = document.getElementById('pm-badge-' + id);

        const action = isEnabled ? 'Enable' : 'Disable';
        const confirmed = await showConfirm(
            action + ' ' + displayName + '?',
            'Cashiers will ' + (isEnabled ? 'be able to use' : 'no longer see') + ' <strong>' + displayName + '</strong> when processing sales.',
            action,
            isEnabled ? 'btn-success' : 'btn-danger'
        );
        if (!confirmed) {
            toggle.checked = !isEnabled;
            return;
        }

        toggle.disabled = true;

        try {
            const response = await fetch('@Url.Action("TogglePaymentMethod", "Settings")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' },
                body: new URLSearchParams({ id, isEnabled, displayName })
            });
            const result = await response.json();

            if (result.success) {
                badge.textContent = isEnabled ? 'Enabled' : 'Disabled';
                badge.className = 'badge ' + (isEnabled ? 'bg-success' : 'bg-secondary');
                card.className = 'card h-100 border ' + (isEnabled ? 'border-success' : 'border-secondary');
                showToast(displayName + (isEnabled ? ' enabled' : ' disabled'), 'success');
            } else {
                toggle.checked = !isEnabled;
                showToast(result.message || 'Update failed', 'error');
            }
        } catch {
            toggle.checked = !isEnabled;
            showToast('Request failed', 'error');
        } finally {
            toggle.disabled = false;
        }
    }
</script>

<!-- Payment Method Confirm Modal -->
<div class="modal fade" id="pmConfirmModal" tabindex="-1" aria-labelledby="pmConfirmTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="pmConfirmTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="pmConfirmBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn" id="pmConfirmBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>
}
