@model Escale.Web.Models.StationDetailsViewModel
@{
    ViewData["Title"] = "Station Details";
    var userRole = Context.Session.GetString("UserRole");
    var isAdmin = userRole == "Admin";
}

@await Html.PartialAsync("_ApiError")

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 page-header">
    <div>
        <h1 class="h2"><i class="fas fa-gas-pump me-2"></i>@Model.Station.Name</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Stations" asp-action="Index">Stations</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Station.Name</li>
            </ol>
        </nav>
    </div>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-controller="Stations" asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white shadow stats-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs mb-1">TODAY'S SALES</div>
                        <div class="h6 mb-0 fw-bold">@Model.Stats.TodaysSales.ToString("N0") RWF</div>
                    </div>
                    <div class="icon-wrapper">
                        <i class="fas fa-dollar-sign fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white shadow stats-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs mb-1">TRANSACTIONS</div>
                        <div class="h6 mb-0 fw-bold">@Model.Stats.TodaysTransactions</div>
                    </div>
                    <div class="icon-wrapper">
                        <i class="fas fa-receipt fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white shadow stats-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs mb-1">EMPLOYEES</div>
                        <div class="h6 mb-0 fw-bold">@Model.Stats.TotalEmployees</div>
                    </div>
                    <div class="icon-wrapper">
                        <i class="fas fa-users fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white shadow stats-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-xs mb-1">LOW STOCK ITEMS</div>
                        <div class="h6 mb-0 fw-bold">@Model.Stats.LowStockItems</div>
                    </div>
                    <div class="icon-wrapper">
                        <i class="fas fa-exclamation-triangle fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<div class="card shadow">
    <div class="card-header" style="background: white; border-bottom: 2px solid var(--border-color);">
        <ul class="nav nav-tabs card-header-tabs border-0" id="stationTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="details-tab" data-bs-toggle="tab" data-bs-target="#details" type="button" role="tab">
                    <i class="fas fa-info-circle me-2"></i>Details
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="sales-tab" data-bs-toggle="tab" data-bs-target="#sales" type="button" role="tab">
                    <i class="fas fa-chart-line me-2"></i>Sales
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="stock-tab" data-bs-toggle="tab" data-bs-target="#stock" type="button" role="tab">
                    <i class="fas fa-boxes me-2"></i>Stock <span class="badge bg-danger">@Model.Stats.LowStockItems</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="employees-tab" data-bs-toggle="tab" data-bs-target="#employees" type="button" role="tab">
                    <i class="fas fa-users me-2"></i>Employees <span class="badge bg-primary">@Model.Stats.TotalEmployees</span>
                </button>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <div class="tab-content" id="stationTabsContent">
            <!-- Details Tab -->
            <div class="tab-pane fade show active" id="details" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <h5 class="mb-3">Station Information</h5>
                        <table class="table table-borderless">
                            <tbody>
                                <tr>
                                    <th width="40%">Station Name:</th>
                                    <td>@Model.Station.Name</td>
                                </tr>
                                <tr>
                                    <th>Location:</th>
                                    <td>@Model.Station.Location</td>
                                </tr>
                                <tr>
                                    <th>Address:</th>
                                    <td>@(Model.Station.Address ?? "N/A")</td>
                                </tr>
                                <tr>
                                    <th>Contact Number:</th>
                                    <td>@(Model.Station.ContactNumber ?? "N/A")</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <h5 class="mb-3">Operational Details</h5>
                        <table class="table table-borderless">
                            <tbody>
                                <tr>
                                    <th width="40%">Manager:</th>
                                    <td>@(Model.Station.ManagerName ?? "Unassigned")</td>
                                </tr>
                                <tr>
                                    <th>Status:</th>
                                    <td>
                                        <span class="badge @(Model.Station.IsActive ? "bg-success" : "bg-secondary")">
                                            @Model.Station.Status
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Created:</th>
                                    <td>@Model.Station.CreatedAt.ToString("yyyy-MM-dd")</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Sales Tab -->
            <div class="tab-pane fade" id="sales" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5>Station Sales</h5>
                    <div class="btn-group" id="salesPeriodBtns">
                        <button type="button" class="btn btn-sm btn-primary active" data-period="today">Today</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-period="week">This Week</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-period="month">This Month</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-period="custom">Custom</button>
                    </div>
                </div>
                <div class="row mb-3 d-none" id="customDateRange">
                    <div class="col-md-4">
                        <label class="form-label">Start Date</label>
                        <input type="date" class="form-control form-control-sm" id="salesStartDate" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">End Date</label>
                        <input type="date" class="form-control form-control-sm" id="salesEndDate" />
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button class="btn btn-sm btn-primary" onclick="loadStationSales()">
                            <i class="fas fa-search me-1"></i>Apply
                        </button>
                    </div>
                </div>

                <!-- Sales Summary Cards -->
                <div class="row mb-3" id="salesSummaryCards">
                    <div class="col-md-4">
                        <div class="card bg-light">
                            <div class="card-body text-center py-2">
                                <div class="text-xs text-muted text-uppercase">Total Sales</div>
                                <div class="h5 mb-0 fw-bold text-primary" id="salesTotal">--</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-light">
                            <div class="card-body text-center py-2">
                                <div class="text-xs text-muted text-uppercase">Transactions</div>
                                <div class="h5 mb-0 fw-bold text-success" id="salesTxnCount">--</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-light">
                            <div class="card-body text-center py-2">
                                <div class="text-xs text-muted text-uppercase">Total Volume</div>
                                <div class="h5 mb-0 fw-bold text-info" id="salesTotalLiters">--</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sales by Fuel Type -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <h6 class="fw-bold">Sales by Fuel Type</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Fuel Type</th>
                                        <th class="text-end">Liters</th>
                                        <th class="text-end">Amount (RWF)</th>
                                        <th class="text-end">Txns</th>
                                    </tr>
                                </thead>
                                <tbody id="salesByFuelBody">
                                    <tr><td colspan="4" class="text-center text-muted">Loading...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <h6 class="fw-bold">Sales by Payment Method</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Payment Method</th>
                                        <th class="text-end">Amount (RWF)</th>
                                        <th class="text-end">Txns</th>
                                    </tr>
                                </thead>
                                <tbody id="salesByPaymentBody">
                                    <tr><td colspan="3" class="text-center text-muted">Loading...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stock Tab -->
            <div class="tab-pane fade" id="stock" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5>Fuel Stock Levels</h5>
                    @if (isAdmin)
                    {
                        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#refillModal">
                            <i class="fas fa-plus me-2"></i>Record Refill
                        </button>
                    }
                </div>
                <div class="row">
                    @foreach (var stock in Model.Stock)
                    {
                        <div class="col-md-4 mb-3">
                            <div class="card @(stock.IsLowStock ? "border-danger" : "")">
                                <div class="card-body">
                                    <h5 class="card-title">
                                        @stock.FuelType
                                        @if (stock.IsLowStock)
                                        {
                                            <span class="badge bg-danger">Low Stock</span>
                                        }
                                    </h5>
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between mb-1">
                                            <small>Current Level</small>
                                            <small><strong>@stock.CurrentLevel.ToString("N0")L / @stock.Capacity.ToString("N0")L</strong></small>
                                        </div>
                                        <div class="progress" style="height: 25px;">
                                            <div class="progress-bar @(stock.IsLowStock ? "bg-danger" : stock.PercentageFull > 70 ? "bg-success" : "bg-warning")"
                                                 style="width: @stock.PercentageFull%">
                                                @stock.PercentageFull.ToString("F1")%
                                            </div>
                                        </div>
                                    </div>
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td>Reorder Level:</td>
                                            <td class="text-end"><strong>@stock.ReorderLevel.ToString("N0")L</strong></td>
                                        </tr>
                                        <tr>
                                            <td>Last Refill:</td>
                                            <td class="text-end">@(stock.LastRefill?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Employees Tab -->
            <div class="tab-pane fade" id="employees" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5>Station Employees</h5>
                    @if (isAdmin)
                    {
                        <a asp-controller="Users" asp-action="Index" class="btn btn-primary btn-sm">
                            <i class="fas fa-user-plus me-2"></i>Manage Users
                        </a>
                    }
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Role</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Employees.Any())
                            {
                                @foreach (var employee in Model.Employees)
                                {
                                    <tr>
                                        <td><strong>@employee.FullName</strong></td>
                                        <td>@(employee.Email ?? "-")</td>
                                        <td>@(employee.Phone ?? "-")</td>
                                        <td>
                                            <span class="badge @(employee.Role == "Manager" ? "bg-primary" : employee.Role == "Cashier" ? "bg-success" : "bg-secondary")">
                                                @employee.Role
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge @(employee.IsActive ? "bg-success" : "bg-secondary")">
                                                @(employee.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-3">No employees assigned to this station. Use the Users page to assign employees.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@if (isAdmin)
{
    <!-- Refill Modal -->
    <div class="modal fade" id="refillModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Record Fuel Refill - @Model.Station.Name</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-controller="Inventory" asp-action="RecordRefill" method="post" data-loading-form>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="inventoryItemId" class="form-label">Fuel Tank <span class="text-danger">*</span></label>
                                <select class="form-select" id="inventoryItemId" name="inventoryItemId" required>
                                    <option value="">Select Fuel Tank</option>
                                    @foreach (var stock in Model.Stock)
                                    {
                                        <option value="@stock.InventoryItemId">@stock.FuelType (@stock.CurrentLevel.ToString("N0")L / @stock.Capacity.ToString("N0")L)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="refillQuantity" class="form-label">Quantity (Liters) <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" id="refillQuantity" name="quantity" required step="0.01" min="0.01" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="refillUnitCost" class="form-label">Unit Cost (RWF) <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" id="refillUnitCost" name="unitCost" required step="0.01" min="0.01" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="refillDate" class="form-label">Refill Date <span class="text-danger">*</span></label>
                                <input type="datetime-local" class="form-control" id="refillDate" name="refillDate" required />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="supplierName" class="form-label">Supplier Name</label>
                                <input type="text" class="form-control" id="supplierName" name="supplierName" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="invoiceNumber" class="form-label">Invoice Number</label>
                                <input type="text" class="form-control" id="invoiceNumber" name="invoiceNumber" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Record Refill
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    $(document).ready(function() {
        $('#refillDate').val(new Date().toISOString().slice(0, 16));

        var today = new Date().toISOString().slice(0, 10);
        $('#salesStartDate').val(today);
        $('#salesEndDate').val(today);

        // Load sales when Sales tab is shown
        $('button[data-bs-target="#sales"]').on('shown.bs.tab', function () {
            loadStationSales();
        });

        // Period button clicks
        $('#salesPeriodBtns button').on('click', function() {
            $('#salesPeriodBtns button').removeClass('btn-primary active').addClass('btn-outline-secondary');
            $(this).removeClass('btn-outline-secondary').addClass('btn-primary active');

            var period = $(this).data('period');
            var now = new Date();
            var start = new Date();

            if (period === 'today') {
                start = now;
                $('#customDateRange').addClass('d-none');
            } else if (period === 'week') {
                start.setDate(now.getDate() - 7);
                $('#customDateRange').addClass('d-none');
            } else if (period === 'month') {
                start.setDate(now.getDate() - 30);
                $('#customDateRange').addClass('d-none');
            } else if (period === 'custom') {
                $('#customDateRange').removeClass('d-none');
                return;
            }

            $('#salesStartDate').val(start.toISOString().slice(0, 10));
            $('#salesEndDate').val(now.toISOString().slice(0, 10));
            loadStationSales();
        });
    });

    function loadStationSales() {
        var startDate = $('#salesStartDate').val();
        var endDate = $('#salesEndDate').val();

        var activeBtn = $('#salesPeriodBtns button.active')[0];
        if (activeBtn) startLoading(activeBtn, 'Loading...');

        $.get('@Url.Action("GetStationSales", "Stations")', {
            id: '@Model.Station.Id',
            startDate: startDate,
            endDate: endDate
        }, function(data) {
            if (!data) {
                $('#salesTotal').text('0 RWF');
                $('#salesTxnCount').text('0');
                $('#salesTotalLiters').text('0L');
                $('#salesByFuelBody').html('<tr><td colspan="4" class="text-center text-muted">No data available</td></tr>');
                $('#salesByPaymentBody').html('<tr><td colspan="3" class="text-center text-muted">No data available</td></tr>');
                return;
            }

            // Summary
            $('#salesTotal').text(Number(data.TotalSales || 0).toLocaleString() + ' RWF');
            $('#salesTxnCount').text(Number(data.TransactionCount || 0).toLocaleString());

            var totalLiters = 0;
            if (data.SalesByFuel) {
                data.SalesByFuel.forEach(function(f) { totalLiters += f.Liters; });
            }
            $('#salesTotalLiters').text(Number(totalLiters).toLocaleString() + 'L');

            // Sales by Fuel Type
            var fuelHtml = '';
            if (data.SalesByFuel && data.SalesByFuel.length > 0) {
                data.SalesByFuel.forEach(function(f) {
                    fuelHtml += '<tr>';
                    fuelHtml += '<td>' + f.FuelType + '</td>';
                    fuelHtml += '<td class="text-end">' + Number(f.Liters).toLocaleString(undefined, {minimumFractionDigits: 1}) + '</td>';
                    fuelHtml += '<td class="text-end">' + Number(f.Amount).toLocaleString() + '</td>';
                    fuelHtml += '<td class="text-end">' + f.TransactionCount + '</td>';
                    fuelHtml += '</tr>';
                });
            } else {
                fuelHtml = '<tr><td colspan="4" class="text-center text-muted">No sales data</td></tr>';
            }
            $('#salesByFuelBody').html(fuelHtml);

            // Sales by Payment Method
            var payHtml = '';
            if (data.SalesByPayment && data.SalesByPayment.length > 0) {
                data.SalesByPayment.forEach(function(p) {
                    payHtml += '<tr>';
                    payHtml += '<td><span class="badge bg-info">' + p.PaymentMethod + '</span></td>';
                    payHtml += '<td class="text-end">' + Number(p.Amount).toLocaleString() + '</td>';
                    payHtml += '<td class="text-end">' + p.TransactionCount + '</td>';
                    payHtml += '</tr>';
                });
            } else {
                payHtml = '<tr><td colspan="3" class="text-center text-muted">No sales data</td></tr>';
            }
            $('#salesByPaymentBody').html(payHtml);
        }).fail(function() {
            $('#salesByFuelBody').html('<tr><td colspan="4" class="text-center text-danger">Failed to load sales data</td></tr>');
            $('#salesByPaymentBody').html('<tr><td colspan="3" class="text-center text-danger">Failed to load sales data</td></tr>');
        }).always(function() {
            if (activeBtn) stopLoading(activeBtn);
        });
    }
</script>
}
