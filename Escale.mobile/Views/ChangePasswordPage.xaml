<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Escale.mobile.ViewModels"
             x:Class="Escale.mobile.Views.ChangePasswordPage"
             x:DataType="vm:ChangePasswordViewModel"
             Title="Change Password"
             BackgroundColor="#F8F9FA"
             Shell.NavBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="Center">

            <!-- Header -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                <Border StrokeShape="RoundRectangle 60"
                        BackgroundColor="#1E3A8A"
                        WidthRequest="80" HeightRequest="80"
                        HorizontalOptions="Center">
                    <Label Text="&#xF0359;"
                           FontFamily="MaterialDesignIcons"
                           FontSize="36"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label Text="Change Password"
                       FontSize="22" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#1E3A8A" />
                <Label Text="Enter your current password and choose a new one"
                       FontSize="13" TextColor="#6B7280"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Error Message -->
            <Border StrokeShape="RoundRectangle 8"
                    BackgroundColor="#FEF2F2"
                    Stroke="#FCA5A5"
                    Padding="12"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#DC2626"
                       FontSize="13" />
            </Border>

            <!-- Form Card -->
            <Border StrokeShape="RoundRectangle 15"
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.1" Radius="10" Offset="0,2"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">

                    <!-- Current Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Current Password" FontSize="13" FontAttributes="Bold" TextColor="#374151" />
                        <Border StrokeShape="RoundRectangle 10" Stroke="#D1D5DB" Padding="4,0">
                            <Entry Text="{Binding CurrentPassword}"
                                   Placeholder="Enter current password"
                                   IsPassword="True"
                                   FontSize="15" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- New Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="New Password" FontSize="13" FontAttributes="Bold" TextColor="#374151" />
                        <Border StrokeShape="RoundRectangle 10" Stroke="#D1D5DB" Padding="4,0">
                            <Entry Text="{Binding NewPassword}"
                                   Placeholder="Enter new password"
                                   IsPassword="True"
                                   FontSize="15" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Confirm Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Confirm New Password" FontSize="13" FontAttributes="Bold" TextColor="#374151" />
                        <Border StrokeShape="RoundRectangle 10" Stroke="#D1D5DB" Padding="4,0">
                            <Entry Text="{Binding ConfirmPassword}"
                                   Placeholder="Confirm new password"
                                   IsPassword="True"
                                   FontSize="15" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Buttons -->
                    <VerticalStackLayout Spacing="10" Margin="0,10,0,0">
                        <!-- Submit Button (normal state) -->
                        <Button Text="Change Password"
                                Command="{Binding SubmitCommand}"
                                BackgroundColor="#1E3A8A"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="16"
                                HeightRequest="50"
                                CornerRadius="10"
                                IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />

                        <!-- Loading state -->
                        <Button Text="Changing..."
                                BackgroundColor="#93C5FD"
                                TextColor="White"
                                FontSize="16"
                                HeightRequest="50"
                                CornerRadius="10"
                                IsEnabled="False"
                                IsVisible="{Binding IsBusy}" />

                        <!-- Cancel Button -->
                        <Button Text="Cancel"
                                Command="{Binding CancelCommand}"
                                BackgroundColor="#F3F4F6"
                                TextColor="#374151"
                                FontSize="15"
                                HeightRequest="45"
                                CornerRadius="10" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
